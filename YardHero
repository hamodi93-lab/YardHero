function getEstimate(serviceType, yardSize) {
  const prices = {
    "Lawn Care": {
      Small: "$35–$65",
      Medium: "$55–$95",
      Large: "$85–$150",
    },
    "Snow Removal": {
      Small: "$30–$55",
      Medium: "$45–$80",
      Large: "$70–$120",
    },
  };

  return prices[serviceType]?.[yardSize] || "Select service";
}

const tests = [
  ["Lawn Care", "Small", "$35–$65"],
