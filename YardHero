  ["Lawn Care", "Large", "$85–$150"],
  ["Snow Removal", "Small", "$30–$55"],
  ["Snow Removal", "Medium", "$45–$80"],
  ["Snow Removal", "Large", "$70–$120"],
];

tests.forEach(([service, size, expected]) => {
  const actual = getEstimate(service, size);
  console.assert(actual === expected, `Estimate test failed for ${service}/${size}: expected ${expected}, got ${actual}`);
});

